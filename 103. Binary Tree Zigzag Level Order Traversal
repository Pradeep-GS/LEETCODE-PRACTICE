class Solution {
    public List<List<Integer>> zigzagLevelOrder(TreeNode root) {
        List<List<Integer>> ans = new ArrayList<>();

        if(root==null){
            return ans;
        }

        Queue<TreeNode> q = new LinkedList<>();
        int count = 0;
        q.offer(root);
        while(!q.isEmpty()){
            List<Integer> temp  = new ArrayList<>();
            int size = q.size();
            for(int i=0;i<size;i++){
                TreeNode node = q.poll();
                temp.add(node.val);
                if(node.left!=null){
                    q.offer(node.left);
                }
                if(node.right!=null){
                    q.offer(node.right);
                }
            }
            if(count % 2 ==0)
            {
                ans.add(temp);
            }
            else{
                Collections.reverse(temp);
                ans.add(temp);
            }
            count++;  
        }
        return ans;
    }
}
