class Solution {
    public ListNode swapPairs(ListNode head) {
        ListNode dummy = new ListNode(0);
        dummy.next = head;
        ListNode ptr = dummy;
        while(ptr.next != null && ptr.next.next != null)
        {
            ListNode first = ptr.next;
            ListNode second = first.next;

            first.next = second.next;
            second.next = first;
            ptr.next = second;

            ptr=first;
        }
        return dummy.next;
    }
}
