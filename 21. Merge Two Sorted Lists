class Solution {
    public ListNode mergeTwoLists(ListNode list1, ListNode list2) {
        ListNode res = new ListNode();
        ListNode ptr = res;

        while(list1!=null && list2!=null)
        {
            if(list1.val<list2.val)
            {
                ptr.next=list1;
                list1=list1.next;
            }
            else
            {
                ptr.next=list2;
                list2=list2.next;
            }
            ptr=ptr.next;
        }
        ptr.next=(list1!=null)?list1:list2;
        return res.next;
    }
}
