class Solution {
    public int[] dailyTemperatures(int[] t) {
        int ans [] = new int[t.length];
        Arrays.fill(ans,0);
        Stack<Integer> stk = new Stack<>();
        for(int i=0;i<t.length;i++){
            if(stk.isEmpty()){
                stk.push(i);
            }
            while(!stk.isEmpty() && t[stk.peek()] < t[i]){
                ans[stk.peek()] = i-stk.pop();
            }
            stk.push(i);
        }
        return ans;
    }
}
